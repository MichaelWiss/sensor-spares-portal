# ──────────────────────────────────────────────
# Supabase
# ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres:password@db.YOUR_PROJECT.supabase.co:5432/postgres

# ──────────────────────────────────────────────
# Medusa.js
# ──────────────────────────────────────────────
MEDUSA_BACKEND_URL=http://localhost:9000
MEDUSA_ADMIN_CORS=http://localhost:3000
MEDUSA_STORE_CORS=http://localhost:3000
MEDUSA_JWT_SECRET=your-jwt-secret
MEDUSA_COOKIE_SECRET=your-cookie-secret

# ──────────────────────────────────────────────
# Stripe
# ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ──────────────────────────────────────────────
# Typesense
# ──────────────────────────────────────────────
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=your-typesense-api-key

# ──────────────────────────────────────────────
# ERPNext
# ──────────────────────────────────────────────
ERPNEXT_URL=https://your-instance.erpnext.com
ERPNEXT_API_KEY=your-api-key
ERPNEXT_API_SECRET=your-api-secret

# ──────────────────────────────────────────────
# Shippo
# ──────────────────────────────────────────────
SHIPPO_API_TOKEN=shippo_test_...

# ──────────────────────────────────────────────
# Boxwise WMS
# ──────────────────────────────────────────────
BOXWISE_API_URL=https://api.boxwise.com
BOXWISE_API_KEY=your-boxwise-api-key

# ──────────────────────────────────────────────
# Resend (email)
# ──────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=alerts@yourdomain.com

# ──────────────────────────────────────────────
# PostHog
# ──────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ──────────────────────────────────────────────
# Own Courier Service
# ──────────────────────────────────────────────
COURIER_DISPATCH_URL=https://dispatch.yourdomain.com/api
COURIER_API_KEY=your-courier-key
COURIER_RADIUS_MILES=50
COURIER_FLAT_RATE_USD=80
